# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=neighbourly_db
DB_USER=neighbourly_user
DB_PASSWORD=neighbourly_pass_2024

# Database Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=5

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# H3 Configuration
H3_DEFAULT_RESOLUTION=9
H3_SEARCH_RESOLUTIONS=7,8,9

# File Upload
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Email Configuration (for future use)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@neighbourly.com
SMTP_FROM_NAME=Neighbourly

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
CORS_CREDENTIALS=true

# API Configuration
API_PREFIX=/api/v1
API_TIMEOUT_MS=30000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Search Configuration
SEARCH_MIN_QUERY_LENGTH=2
SEARCH_MAX_RESULTS=100

# Service Configuration
DEFAULT_SERVICE_RADIUS_KM=5
MAX_SERVICE_RADIUS_KM=100

# Booking Configuration
MIN_BOOKING_ADVANCE_HOURS=2
MAX_BOOKING_ADVANCE_DAYS=90
CANCELLATION_WINDOW_HOURS=24

# Payment Configuration (for future use)
PLATFORM_FEE_PERCENTAGE=10
CURRENCY_DEFAULT=USD

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Feature Flags
ENABLE_CACHE=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGS=true