{
  "name": "neighbourly-backend",
  "version": "1.0.0",
  "description": "Backend service for Neighbourly – a hyper-local services marketplace",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/database/runMigrations.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "node",
    "express",
    "sqlite",
    "marketplace",
    "backend",
    "rest-api"
  ],
  "author": "Team Neighbourly",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.3"
  }
}
